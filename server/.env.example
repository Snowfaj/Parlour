# Database — PostgreSQL connection string
# For local: postgresql://username:password@localhost:5432/parlour_booking
# For Supabase/Render: get from dashboard
DATABASE_URL="postgresql://postgres:password@localhost:5432/parlour_booking"

# JWT — use a long random string (min 32 chars)
JWT_SECRET="your_super_secret_jwt_key_change_this_in_production"
JWT_EXPIRES_IN="7d"

# Razorpay — get from https://dashboard.razorpay.com/
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"

# Email — Gmail SMTP (use App Password)
# Guide: Google Account > Security > 2-Step Verification > App Passwords
EMAIL_USER="your_gmail@gmail.com"
EMAIL_PASS="your_gmail_app_password"
ADMIN_EMAIL="admin@parlour.com"

# App Config
PORT=5000
CLIENT_URL="http://localhost:5173"
